"""
Creates and seeds users.db for the demo app.
Run this once before starting app.py.
"""

import sqlite3
import os

DB_PATH = "users.db"

if os.path.exists(DB_PATH):
    os.remove(DB_PATH)

conn = sqlite3.connect(DB_PATH)
cur = conn.cursor()

cur.execute("""
    CREATE TABLE users (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        username TEXT NOT NULL UNIQUE,
        password TEXT NOT NULL,
        role TEXT NOT NULL
    )
""")

# NOTE: plaintext passwords here are intentional, for the vulnerability demo.
demo_users = [
    ("admin", "admin123", "admin"),
    ("alice", "alice123", "user"),
    ("bob", "bobpass", "user"),
]

cur.executemany(
    "INSERT INTO users (username, password, role) VALUES (?, ?, ?)",
    demo_users
)

conn.commit()
conn.close()

print(f"Database '{DB_PATH}' created and seeded with {len(demo_users)} users.")
