import sqlite3

DB_PATH = "users.db"


def get_connection():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def authenticate_user(username, password):
    """
    VULNERABLE: builds SQL using string concatenation/formatting.
    An attacker can break out of the intended query using input like:

        username:  admin' OR '1'='1
        password:  anything

    which turns the query into:

        SELECT * FROM users WHERE username = 'admin' OR '1'='1' AND password = 'anything'

    ...which can return a row even without knowing the real password.
    """
    conn = get_connection()
    cur = conn.cursor()

    # --- VULNERABLE LINE (SQL Injection) ---
    query = "SELECT * FROM users WHERE username = '" + username + \
            "' AND password = '" + password + "'"
    cur.execute(query)
    # ----------------------------------------

    user = cur.fetchone()
    conn.close()
    return user


def get_user_by_username(username):
    """Used by the exploit/security-check script to show what data exists."""
    conn = get_connection()
    cur = conn.cursor()
    query = "SELECT * FROM users WHERE username = '" + username + "'"
    cur.execute(query)
    user = cur.fetchone()
    conn.close()
    return user
