"""
CONTROLLER LAYER (Layer 3/4 of the MVC app)
---------------------------------------------
Receives requests from the View (HTML form), passes data to the Model,
and decides what response/authorization the user gets based on their role.

Run with:
    python setup_db.py
    python app.py
Then open http://127.0.0.1:5000/login
"""

from flask import Flask, request, render_template, redirect, session, url_for
import model

app = Flask(__name__)
app.secret_key = "dev-secret-key"  # fine for local demo only


@app.route("/")
def home():
    return redirect(url_for("login"))


@app.route("/login", methods=["GET", "POST"])
def login():
    error = None
    if request.method == "POST":
        username = request.form.get("username", "")
        password = request.form.get("password", "")

        user = model.authenticate_user(username, password)

        if user:
            # Authorization: store identity + role in session
            session["username"] = user["username"]
            session["role"] = user["role"]
            return redirect(url_for("dashboard"))
        else:
            error = "Invalid username or password."

    return render_template("login.html", error=error)


@app.route("/dashboard")
def dashboard():
    if "username" not in session:
        return redirect(url_for("login"))

    # Role-based content (simple authorization demo)
    if session["role"] == "admin":
        message = f"Welcome ADMIN {session['username']}. You have full access rights."
    else:
        message = f"Welcome {session['username']}. You have standard user access."

    return render_template("dashboard.html", message=message, role=session["role"])


@app.route("/logout")
def logout():
    session.clear()
    return redirect(url_for("login"))


if __name__ == "__main__":
    app.run(debug=True)
